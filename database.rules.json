{
  "rules": {
    ".read": false,
    ".write": false,
    "tests": {
      ".read": true,
      "$code": {
        ".read": true,
        ".write": "!newData.exists() || newData.hasChildren(['code','title','testType','durationMinutes','questions','answerKey','createdAtIso','creator'])",
        "code": {
          ".validate": "newData.isString() && newData.val() === $code"
        },
        "title": {
          ".validate": "newData.isString() && newData.val().length <= 120"
        },
        "testType": {
          ".validate": "newData.isString() && (newData.val() === 'standard' || newData.val() === 'reading' || newData.val() === 'mixed')"
        },
        "durationMinutes": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 300"
        },
        "createdAtIso": {
          ".validate": "newData.isString()"
        },
        "creator": {
          ".validate": "newData.hasChildren(['uid','username','displayName'])"
        },
        "questions": {
          ".validate": "newData.exists()"
        },
        "answerKey": {
          ".validate": "newData.exists()"
        },
        "passages": {
          ".validate": "(newData.parent().child('testType').val() === 'standard' && !newData.exists()) || ((newData.parent().child('testType').val() === 'reading' || newData.parent().child('testType').val() === 'mixed') && newData.exists() && newData.hasChildren())"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "teacherUsernames": {
      "$username": {
        ".read": true,
        ".write": "(!data.exists() && newData.hasChildren(['uid','email','username'])) || !newData.exists()",
        "uid": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length <= 160"
        },
        "username": {
          ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 32"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "teachers": {
      ".read": true,
      "$uid": {
        ".read": true,
        ".write": true,
        "uid": {
          ".validate": "newData.isString() && newData.val() === $uid"
        },
        "firstName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60"
        },
        "lastName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60"
        },
        "gender": {
          ".validate": "newData.isString() && (newData.val() === 'female' || newData.val() === 'male' || newData.val() === 'other' || newData.val() === 'prefer_not_to_say')"
        },
        "phoneNumber": {
          ".validate": "newData.isString() && newData.val().length >= 8 && newData.val().length <= 20"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length <= 160"
        },
        "username": {
          ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 32"
        },
        "normalizedUsername": {
          ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 32"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'pending' || newData.val() === 'approved' || newData.val() === 'rejected')"
        },
        "createdAtIso": {
          ".validate": "newData.isString()"
        },
        "approvedAtIso": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "rejectedAtIso": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "results": {
      "$testCode": {
        ".read": true,
        "$attemptId": {
          ".read": true,
          ".write": "!data.exists() && newData.hasChildren(['id','testCode','studentName','studentClassName','totalQuestions','correctAnswers','percentage','submittedAtIso','answers','details'])",
          "id": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "testCode": {
            ".validate": "newData.isString() && newData.val() === $testCode"
          },
          "studentName": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120"
          },
          "studentClassName": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60"
          },
          "totalQuestions": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
          },
          "correctAnswers": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= newData.parent().child('totalQuestions').val()"
          },
          "percentage": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
          },
          "submittedAtIso": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "answers": {
            ".validate": "newData.exists()",
            "$questionNumber": {
              ".validate": "newData.isString() && (newData.val() === 'A' || newData.val() === 'B' || newData.val() === 'C' || newData.val() === 'D')"
            }
          },
          "details": {
            ".validate": "newData.exists()",
            "$index": {
              "questionNumber": {
                ".validate": "newData.isNumber() && newData.val() > 0"
              },
              "selected": {
                ".validate": "newData.isString() && (newData.val() === 'A' || newData.val() === 'B' || newData.val() === 'C' || newData.val() === 'D' || newData.val() === 'N/A')"
              },
              "correct": {
                ".validate": "newData.isString() && (newData.val() === 'A' || newData.val() === 'B' || newData.val() === 'C' || newData.val() === 'D')"
              },
              "isCorrect": {
                ".validate": "newData.isBoolean()"
              },
              "$other": {
                ".validate": false
              }
            }
          },
          "$other": {
            ".validate": false
          }
        }
      }
    }
  }
}